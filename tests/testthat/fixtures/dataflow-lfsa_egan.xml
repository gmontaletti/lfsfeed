<s:Codelist agencyID="ESTAT" id="GEO" isFinal="true" urn="urn:sdmx:org.sdmx.infomodel.codelist.Codelist=ESTAT:GEO(28.0)" version="28.0"><c:Annotations><c:Annotation><c:AnnotationTitle>2026-03-25T23:00:00+0100</c:AnnotationTitle><c:AnnotationType>LAST_UPDATED</c:AnnotationType></c:Annotation><c:Annotation><c:AnnotationTitle>C</c:AnnotationTitle><c:AnnotationType>IS_STANDARD_CODE_LIST</c:AnnotationType><c:AnnotationText xml:lang="en">Combined code list, contains standard codes and codes not associated with the concept of the code list</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationType>ARTEFACT_SOURCE</c:AnnotationType><c:AnnotationText xml:lang="en">Eurostat Standard Code Lists</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationType>EXPLAN_LABEL</c:AnnotationType><c:AnnotationText xml:lang="en">The geographical standard code list provides codes on geographical entities at the level of aggregates, countries, regions and organizations; the labels are available in EN, DE and FR and they are in line with the EU Interinstitutional Style Guide. The work is based on various international sources:  Interinstitutional Style Guide, ISO 3166 country codes (3166-1 alpha-2), UN standard country and area codes classification. The structure follows the UN standard country or area code classification (M49) and adopts in most of the cases the proposed geographical order. In case of conflict, the most appropriate solution in the interest of the ESS has been chosen. The country codes correspond to the ISO 3166 classification with the exception of: United Kingdom where the code UK was adopted (instead of GB) and Greece where the code EL was adopted (instead of GR) in order to comply with the Interinstitutional Style Guide. The presentation of the code list has been enhanced with additional information on the composition of the aggregates and on the dependency status of various geographical entities (mainly overseas territories). ISO 3166-1-alpha-2 - ISO 3166 International Standard for country codes; NUTS</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationTitle>N</c:AnnotationTitle><c:AnnotationType>DERIVED</c:AnnotationType><c:AnnotationText xml:lang="en">Not derived</c:AnnotationText></c:Annotation></c:Annotations><c:Name xml:lang="en">Geopolitical entity (reporting)</c:Name><c:Name xml:lang="de">Geopolitische Meldeeinheit</c:Name><c:Name xml:lang="fr">Entité géopolitique (déclarante)</c:Name><c:Description xml:lang="en">This code list defines the reporting geopolitical entities.</c:Description><s:Code id="EU27_2020" urn="urn:sdmx:org.sdmx.infomodel.codelist.Code=ESTAT:GEO(28.0).EU27_2020"><c:Annotations><c:Annotation><c:AnnotationTitle>Y</c:AnnotationTitle><c:AnnotationType>IS_STANDARD_CODE</c:AnnotationType><c:AnnotationText xml:lang="en">Standard code, follows Eurostat Standard Code List Guidelines</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationType>EXPLAN_LABEL</c:AnnotationType><c:AnnotationText xml:lang="en">This aggregate covers following countries: BE, BG, CZ, DK, DE, EE, IE, EL, ES, FR, HR, IT, CY, LV, LT, LU, HU, MT, NL, AT, PL, PT, RO, SI, SK, FI, SE</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationTitle>EUR</c:AnnotationTitle><c:AnnotationType>EC_CORPORATE_CODE</c:AnnotationType><c:AnnotationURL>http://publications.europa.eu/resource/authority/country/EUR</c:AnnotationURL></c:Annotation><c:Annotation><c:AnnotationTitle>AGG</c:AnnotationTitle><c:AnnotationType>LEVEL</c:AnnotationType></c:Annotation></c:Annotations><c:Name xml:lang="en">European Union - 27 countries (from 2020)</c:Name><c:Name xml:lang="de">Europäische Union - 27 Länder (ab 2020)</c:Name><c:Name xml:lang="fr">Union européenne - 27 pays (à partir de 2020)</c:Name></s:Code><s:Code id="EU28" urn="urn:sdmx:org.sdmx.infomodel.codelist.Code=ESTAT:GEO(28.0).EU28"><c:Annotations><c:Annotation><c:AnnotationTitle>Y</c:AnnotationTitle><c:AnnotationType>IS_STANDARD_CODE</c:AnnotationType><c:AnnotationText xml:lang="en">Standard code, follows Eurostat Standard Code List Guidelines</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationType>EXPLAN_LABEL</c:AnnotationType><c:AnnotationText xml:lang="en">This aggregate covers following countries: BE, BG, CZ, DK, DE, EE, IE, EL, ES, FR, HR, IT, CY, LV, LT, LU, HU, MT, NL, AT, PL, PT, RO, SI, SK, FI, SE, UK</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationTitle>AGG</c:AnnotationTitle><c:AnnotationType>LEVEL</c:AnnotationType></c:Annotation></c:Annotations><c:Name xml:lang="en">European Union - 28 countries (2013-2020)</c:Name><c:Name xml:lang="de">Europäische Union - 28 Länder (2013-2020)</c:Name><c:Name xml:lang="fr">Union européenne - 28 pays (2013-2020)</c:Name></s:Code><s:Code id="EA20" urn="urn:sdmx:org.sdmx.infomodel.codelist.Code=ESTAT:GEO(28.0).EA20"><c:Annotations><c:Annotation><c:AnnotationTitle>Y</c:AnnotationTitle><c:AnnotationType>IS_STANDARD_CODE</c:AnnotationType><c:AnnotationText xml:lang="en">Standard code, follows Eurostat Standard Code List Guidelines</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationType>EXPLAN_LABEL</c:AnnotationType><c:AnnotationText xml:lang="en">This aggregate covers following countries since 2023: BE, DE, EE, IE, EL, ES, FR, HR, IT, CY, LV, LT, LU, MT, NL, AT, PT, SI, SK, FI</c:AnnotationText></c:Annotation><c:Annotation><c:AnnotationTitle>AGG</c:AnnotationTitle><c:AnnotationType>LEVEL</c:AnnotationType></c:Annotation></c:Annotations><c:Name xml:lang="en">Euro area – 20 countries (2023-2025)</c:Name><c:Name xml:lang="de">Euroraum - 20 Länder (2023-2025)</c:Name><c:Name xml:lang="fr">Zone euro - 20 pays (2023-2025)</c:Name></s:Code><s:Code id="BE" urn="urn:sdmx:org.sdmx.infomodel.codelist.Code=ESTAT:GEO(28.0).BE"><c:Annotations><c:Annotation><c:AnnotationTitle>Y</c:AnnotationTitle><c:AnnotationType>IS_STANDARD_CODE</c:AnnotationType><c:AnnotationText xml:lang="en">Standard code, follows Eurostat Standard Code List Guidelines</c:AnnotationText></c:Annotation><c:Annotation><c:Anno